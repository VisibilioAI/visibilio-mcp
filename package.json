{
  "name": "@visibilio/mcp",
  "version": "0.1.1",
  "description": "MCP server for Visibilio AI content platform (TypeScript)",
  "type": "module",
  "bin": {
    "visibilio-mcp": "dist/cli.js"
  },
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "files": [
    "dist",
    "spec",
    "README.md",
    "GLOSSARY.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "dev:http": "tsx src/http.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts && prettier --check 'src/**/*.ts' 'tests/**/*.ts'",
    "lint:fix": "eslint . --ext .ts --fix && prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.0",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "visibilio",
    "mcp",
    "model-context-protocol",
    "ai",
    "content"
  ],
  "author": "Visibilio AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/VisibilioAI/visibilio-mcp.git"
  },
  "publishConfig": {
    "access": "public"
  }
}
